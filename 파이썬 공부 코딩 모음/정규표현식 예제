from operator import and_

import re #regular expression,정규표현식

strdata='파이썬 Ai PYThone3 Progeamming97 성장 2026A+ B- C+ ALL In ONe!! 빅테크 '
#문자열 매서드가 아닌 특정 패턴을 활용해서 특정 문자열을 찾고(검색),분할하고,치환(삭제),할수 있는 정규 표현식 메서드 지원

#검색==>findall(패턴,찾을문자열)==>패턴에 매칭된 모든 내용을 리스트 형태로 반환
#영문대문자패턴==>A,B,C....Z==>범위를 활용A-Z
#[]=>여러개의 패턴을 하나로 묶어서 표현할때 사용하는 메타문자
#+==> +기호앞에 있는 패턴이 하나 이상인 문자를 찾아서 반환해라==>메타문자
result=re.findall(r'[A-Z]+',strdata)
print(result)

#영문 소문자패턴
result=re.findall(r'[a-z]',strdata)
print(result) # i o n r o g r a .....e

#영문 대소문자로 이루어진 출력
result=re.findall(r'[A-Za-z]+',strdata)
print(result)

#한글이 하나이상 찾아서 출력
# 가-힣:완성형 범위
# ㄱ-힣:조합형 범위
result=re.findall(r'[ㄱ-힣]+',strdata)
print(result)
#숫자,문자가 하나 이상인 것을 모두 찾아서 출력
result=re.findall(r'[0-9a-zA-Zㄱ-힣]+',strdata)
print(result)

if result:
    print('있음')
else:
    print('없어요')
#[]== False(논리)
#논리 부정(반대)==>not
# 논리 and==>and
# 논리 or==>or



